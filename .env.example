# ─────────────────────────────────────────────────────────────
# Token Distribution Wizard — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env with real private keys to source control
# ─────────────────────────────────────────────────────────────

# ── Optional: skip interactive RPC prompt ────────────────────
# RPC_URL=https://bsc-dataseed1.binance.org

# ── Optional: skip interactive private key prompt ────────────
# Provide with or without 0x prefix
# PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE  # Deployer wallet private key (64 hex chars, no 0x prefix required)

# ── Optional: default token address ─────────────────────────
# TOKEN_ADDRESS=0xYourTokenAddress

# ── Optional: BSC-specific (used by bsc_revenue_transfer.py) ─
# BSC_PRIVATE_KEY=0xYOUR_BSC_PRIVATE_KEY_HERE  # Deployer wallet private key
# BSC_AMOUNT_BNB=$1.1
# BSC_TOKEN_ADDRESS=0x55d398326f99059ff775485246999027b3197955
# BSC_TOKEN_AMOUNT=30000000000000000000000000
# BSCSCAN_API_KEY=your_bscscan_api_key_here


# ── Alchemy (for alchemy_token_balances.py) ──────────────────
# ALCHEMY_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
